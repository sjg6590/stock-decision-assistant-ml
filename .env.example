# Copy to .env and fill in values — never commit .env (see .gitignore).
# Also copy config/watchlist.example.yaml and config/thresholds.example.yaml
# to config/watchlist.yaml and config/thresholds.yaml before first run.
#
# =============================================================================
# Schwab API (required for market data and OAuth)
# Register an app at https://developer.schwab.com/ and copy API key + secret.
# Run `python scripts/schwab_login.py` (or `python -m main schwab-login`) once
# to create the token file at SCHWAB_TOKEN_PATH.
# =============================================================================

# App API key from Schwab developer portal
SCHWAB_API_KEY=

# App secret from Schwab developer portal
SCHWAB_APP_SECRET=

# OAuth redirect URI; must exactly match the callback URL registered for your app
SCHWAB_CALLBACK_URL=https://127.0.0.1

# Path where Schwab OAuth tokens are read/written after login
SCHWAB_TOKEN_PATH=./secrets/token.json

# =============================================================================
# News data (optional; improves sentiment coverage)
# If omitted, yfinance headlines are still used (no API key required).
# Optional Anthropic web search adds another source when ANTHROPIC_WEB_SEARCH_ENABLED=true.
# =============================================================================

# NewsAPI.org key — https://newsapi.org/register
# Free developer tier is ~100 requests/day; expect HTTP 429 on large watchlists.
NEWSAPI_KEY=

# Optional seconds to wait between NewsAPI calls (e.g. 1.5) to reduce rate-limit errors
NEWSAPI_DELAY_SECONDS=0

# Alpha Vantage key — https://www.alphavantage.co/support/#api-key
# Free tier has strict daily rate limits; keep the watchlist small.
ALPHAVANTAGE_KEY=

# =============================================================================
# LLM sentiment analysis
# Set LLM_PROVIDER to one of: openai | anthropic | ollama
# Only configure the variables for your chosen provider.
# =============================================================================

# Active provider: openai (default), anthropic, or ollama
LLM_PROVIDER=openai

# --- openai: requires OPENAI_API_KEY (uses model gpt-4o-mini) ---
OPENAI_API_KEY=

# --- anthropic: requires ANTHROPIC_API_KEY ---
ANTHROPIC_API_KEY=
# Model for sentiment and optional web-search news fetch (default: claude-haiku-4-5-20251001).
# Haiku works with web search when allowed_callers=direct (configured in code). For Sonnet/Opus
# web search + dynamic filtering, use e.g. claude-sonnet-4-6.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Enable Anthropic server-side web search (web_search_20260209) during news ingest.
# Must be turned on in Claude Console → Settings → Privacy.
ANTHROPIC_WEB_SEARCH_ENABLED=false
# Also run web_search during sentiment (doubles API calls; usually leave false).
ANTHROPIC_WEB_SEARCH_ON_SENTIMENT=false
# Max web searches per ingest call (default 2).
ANTHROPIC_WEB_SEARCH_MAX_USES=2
# Pause between Anthropic API calls when scanning a watchlist (reduces HTTP 429).
# Large watchlists (20+ symbols) often need 6–8+ to stay under input TPM limits.
ANTHROPIC_DELAY_SECONDS=2

# --- ollama: local server; no cloud API key needed ---
# Base URL of your Ollama instance (default local install)
OLLAMA_BASE_URL=http://localhost:11434
# Model name as shown by `ollama list` (e.g. llama3.1, mistral, qwen2.5)
OLLAMA_MODEL=llama3.1

# HTTP timeout for LLM calls (seconds). Local Ollama models often need 120–300.
LLM_TIMEOUT_SECONDS=180

# Max news headlines sent to the LLM (Anthropic caps at 8, Ollama at 12 in code)
LLM_ARTICLE_LIMIT=25

# =============================================================================
# Paths and local storage
# =============================================================================

# YAML list of ticker symbols to scan each cycle
WATCHLIST_PATH=./config/watchlist.yaml

# YAML thresholds for training, promotion gates, and signal fusion
# Parameter reference: config/thresholds.example.yaml
THRESHOLDS_PATH=./config/thresholds.yaml

# SQLite database for bars, news, signals, and alert deduplication
SQLITE_PATH=./data/stock_assistant.sqlite

# Parquet files for historical bar/news snapshots
PARQUET_DIR=./data/parquet

# Trained model artifacts: data/models/{SYMBOL}/{VERSION}/
MODEL_DIR=./data/models

# =============================================================================
# Runtime behavior
# =============================================================================

# true: log alerts only, do not send email/SMS/Telegram/ntfy
# false: send alerts on all configured channels below
DRY_RUN=true

# Suppress repeat alerts for the same symbol/signal within this many hours
ALERT_DEDUP_HOURS=24

# Colorize terminal log output (set false or export NO_COLOR=1 to disable)
LOG_COLORS=true

# =============================================================================
# Alert channels (all optional; configure only what you use)
# Channels with missing credentials are skipped silently.
# =============================================================================

# --- Email (SMTP) ---
# SMTP server hostname (e.g. smtp.gmail.com, smtp.sendgrid.net)
SMTP_HOST=
# SMTP port (587 is typical for STARTTLS)
SMTP_PORT=587
# Login username; leave empty if your server allows unauthenticated relay
SMTP_USER=
SMTP_PASSWORD=
# From address; defaults to SMTP_USER if empty
SMTP_FROM=
# Recipient for trade alerts
ALERT_EMAIL_TO=

# --- SMS via Twilio — https://www.twilio.com/ ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Twilio phone number in E.164 format (e.g. +15551234567)
TWILIO_FROM_NUMBER=
# Your mobile number in E.164 format
ALERT_SMS_TO=

# --- Telegram — create a bot via @BotFather, get chat id from @userinfobot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- ntfy — https://ntfy.sh/ (topic name only; posts to https://ntfy.sh/{topic}) ---
NTFY_TOPIC=
